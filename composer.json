{
  "name": "jord-jd/eloquent-attribute-value-prediction",
  "description": "Predict attribute values for your Laravel Eloquent models using machine learning!",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": "^7.4 || ^8.0",
    "laravel/framework": "^5.1||^6.0||^7.0||^8.0||^9.0||^10.0||^11.0||^12.0||^13.0",
    "rubix/ml": "^2.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5||^9.6||^10.5||^11.5||^12.0",
    "calebporzio/sushi": "^2.5",
    "orchestra/testbench": "^3.8||^4.0||^5.0||^6.0||^7.0||^8.0||^9.0||^10.0||^11.0"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\EloquentAttributeValuePrediction\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\EloquentAttributeValuePrediction\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "JordJD\\EloquentAttributeValuePrediction\\ServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-master": "3.x-dev"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "kylekatarnls/update-helper": false
    }
  },
  "replace": {
    "divineomega/eloquent-attribute-value-prediction": "self.version"
  }
}
